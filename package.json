{
  "name": "qoredb-showcase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "tsx scripts/generate-image-variants.ts",
    "dev": "next dev",
    "build": "tsx scripts/generate-image-variants.ts && tsc --noEmit && tsx scripts/fetch-stats.ts && next build && tsx scripts/build-search-index.ts",
    "build:next": "next build",
    "typecheck": "tsc --noEmit",
    "build:search": "tsx scripts/build-search-index.ts",
    "build:images": "tsx scripts/generate-image-variants.ts",
    "build:stats": "tsx scripts/fetch-stats.ts",
    "export:subscribers": "tsx scripts/export-subscribers.ts",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "test:license": "tsx --test lib/license/generate.test.ts"
  },
  "dependencies": {
