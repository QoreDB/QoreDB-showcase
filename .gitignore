# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# pagefind (generated docs search index)
/public/pagefind

# responsive image variants (generated by scripts/generate-image-variants.ts)
# The manifest lib/image-variants.generated.ts IS committed (needed by tsc/dev),
# but the binary WebP variants are regenerated at build/dev time.
/public/images/**/*-[0-9]*.webp

# typescript
*.tsbuildinfo
next-env.d.ts
